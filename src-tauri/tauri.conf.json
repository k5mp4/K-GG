{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KAGARIBI Grad",
  "version": "0.1.1",
  "identifier": "com.kagaribi.grad",
  "build": {
    "beforeDevCommand": "npm run dev:local",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KAGARIBI Grad",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --force_high_performance_gpu --enable-gpu-rasterization",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "Japanese"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3OTI4NjJGMDZFMThFRUIKUldUcmp1RUdMNGFTNXdtb0NGdUZqWUJTWXAxQUEzSGlUSkJISG05bnNna1ZrUFZoM1lDS2lGblYK",
      "endpoints": [
        "https://github.com/k5mp4/K-GG/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
