{
  "name": "k-gg",
  "private": true,
  "version": "0.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:lan": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --bundles nsis --target x86_64-pc-windows-msvc",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "npm run release:check && npm run docs:check && npm run docs:build && npm test && npm run lint && npm run build && cargo test --manifest-path src-tauri/Cargo.toml && cargo check --manifest-path src-tauri/Cargo.toml",
    "verify:windows": "pwsh -NoProfile -File tools/verify-windows.ps1",
    "updater:key": "node tools/set-updater-public-key.mjs",
    "release:version": "node tools/release-version.mjs set",
    "release:check": "node tools/release-version.mjs check",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "docs:dev": "vitepress dev docs",
    "docs:check": "node tools/check-docs.mjs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:lint": "markdownlint docs/**/*.md",
    "docs:fix": "markdownlint --fix docs/**/*.md"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "fflate": "^0.8.2",
    "gsap": "^3.14.2",
    "ogl": "^1.0.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "tweeq": "file:vendor/tweeq",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
